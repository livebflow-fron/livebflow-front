<script>
document.addEventListener('DOMContentLoaded', function() {
    // Tab switching
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabContents = document.querySelectorAll('.tab-content');

    tabBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            const tabId = this.dataset.tab;

            // Update buttons
            tabBtns.forEach(b => {
                b.classList.remove('active', 'bg-white', 'text-gray-800', 'shadow-md');
                b.classList.add('text-gray-500');
            });
            this.classList.add('active', 'bg-white', 'text-gray-800', 'shadow-md');
            this.classList.remove('text-gray-500');

            // Update content - hide all tabs
            tabContents.forEach(c => {
                c.classList.add('hidden');
                c.classList.remove('block');
            });

            // Show selected tab
            const selectedTab = document.getElementById('tab-' + tabId);
            selectedTab.classList.remove('hidden');
            selectedTab.classList.add('block');
        });
    });

    // CEP auto-complete for Imobiliária
    const cepImobiliaria = document.getElementById('id_imobiliaria-cep');
    if (cepImobiliaria) {
        cepImobiliaria.addEventListener('blur', function() {
            const cep = this.value.replace(/\D/g, '');
            if (cep.length === 8) {
                fetch(`https://viacep.com.br/ws/${cep}/json/`)
                    .then(response => response.json())
                    .then(data => {
                        if (!data.erro) {
                            document.getElementById('id_imobiliaria-endereco').value = data.logradouro;
                        }
                    });
            }
        });
    }

    // CEP auto-complete for Corretor
    const cepCorretor = document.getElementById('id_corretor-cep');
    if (cepCorretor) {
        cepCorretor.addEventListener('blur', function() {
            const cep = this.value.replace(/\D/g, '');
            if (cep.length === 8) {
                fetch(`https://viacep.com.br/ws/${cep}/json/`)
                    .then(response => response.json())
                    .then(data => {
                        if (!data.erro) {
                            document.getElementById('id_corretor-endereco').value = data.logradouro;
                        }
                    });
            }
        });
    }

    // Input masks
    function applyMask(input, mask) {
        input.addEventListener('input', function(e) {
            let value = e.target.value.replace(/\D/g, '');
            let maskedValue = '';
            let maskIndex = 0;

            for (let i = 0; i < value.length && maskIndex < mask.length; i++) {
                while (maskIndex < mask.length && mask[maskIndex] !== '0') {
                    maskedValue += mask[maskIndex];
                    maskIndex++;
                }
                if (maskIndex < mask.length) {
                    maskedValue += value[i];
                    maskIndex++;
                }
            }
            e.target.value = maskedValue;
        });
    }

    // Apply masks to all inputs with data-mask
    document.querySelectorAll('[data-mask]').forEach(input => {
        applyMask(input, input.dataset.mask);
    });
});
</script>

</body>
